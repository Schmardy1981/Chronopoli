# ============================================================
# Chronopoli Extensions – Environment Variables
# Copy to .env and fill in values.
# Most values come from: terraform output engineer_env_config
# ============================================================

# === Domain ===
CHRONOPOLI_DOMAIN=chronopoli.io

# === AWS ===
AWS_REGION=me-central-1
AWS_ACCESS_KEY_ID=CHANGE_THIS
AWS_SECRET_ACCESS_KEY=CHANGE_THIS

# === MySQL (RDS) — same instance as OpenEdX ===
MYSQL_HOST=CHANGE_THIS
MYSQL_PORT=3306
MYSQL_ROOT_USERNAME=admin
MYSQL_ROOT_PASSWORD=CHANGE_THIS

# === Opencast ===
OPENCAST_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
OPENCAST_S3_BUCKET=chronopoli-opencast-production
CLOUDFRONT_DOMAIN=CHANGE_THIS

# === Opencast LTI (for OpenEdX integration) ===
OPENCAST_LTI_KEY=chronopoli_opencast
OPENCAST_LTI_SECRET=CHANGE_THIS_32_CHAR_SECRET

# === Presenton ===
PRESENTON_ANTHROPIC_KEY=CHANGE_THIS
PRESENTON_PEXELS_KEY=CHANGE_THIS

# === Discourse ===
DISCOURSE_HOSTNAME=community.chronopoli.io
DISCOURSE_ADMIN_EMAIL=admin@chronopoli.io
DISCOURSE_SSO_SECRET=CHANGE_THIS_64_CHAR_SECRET
DISCOURSE_API_KEY=CHANGE_THIS_AFTER_SETUP

# === SES (email — shared with OpenEdX) ===
SMTP_HOST=email-smtp.me-central-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_THIS
SMTP_PASSWORD=CHANGE_THIS
