# ============================================================
# Chronopoli – Production Terraform Variables
# Copy this file to production.tfvars and fill in values.
# NEVER commit the real production.tfvars file.
# ============================================================

aws_region    = "me-central-1"
environment   = "production"
project_name  = "chronopoli"

# EC2
ec2_instance_type    = "t3.xlarge"
ec2_key_name         = "chronopoli-production-key"
ec2_root_volume_size = 50
ec2_data_volume_size = 100
admin_ssh_cidr       = "YOUR_IP/32"

# RDS
rds_instance_class       = "db.t3.medium"
rds_allocated_storage    = 50
rds_max_allocated_storage = 200
rds_db_name              = "openedx"
rds_username             = "admin"
rds_password             = "CHANGE_THIS_STRONG_PASSWORD"
rds_multi_az             = true

# Domain
domain_name   = "chronopoli.io"
lms_subdomain = "learn"
cms_subdomain = "studio"

# Tags
tags = {
  Project      = "Chronopoli"
  ManagedBy    = "Terraform"
  Organization = "DBCC"
  Environment  = "production"
}
